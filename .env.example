# Variáveis de ambiente — copie para .env e ajuste os valores
# cp .env.example .env

# ── Docker Compose (docker-compose.yml) ──────────────────────────
# Os valores abaixo já funcionam para um Quick Start local.
# Em produção real, troque todos por valores próprios e seguros.
DB_USER=greencap
DB_PASSWORD=changeme
ENCRYPTION_KEY=change-me-in-production-32x-min

# ── Desenvolvimento local com Gradle (docker-compose.dev.yml) ────
# Chave de encriptação do kubeconfig (mínimo 32 caracteres)
GREENCAP_ENCRYPTION_KEY=dev-encryption-key-change-me-32x
